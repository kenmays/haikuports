SUMMARY="Experimental V.Smile emulator"
DESCRIPTION="veesem is an experimental V.Smile emulator. Game compatibility is generally quite \
good from what I have tested so far, though more features, a more advanced UI and better accuracy \
are future targets."
HOMEPAGE="https://github.com/sp1187/veesem"
COPYRIGHT="2024-2026 Simon Eriksson"
LICENSE="ISC"
SOURCE_URI="https://github.com/sp1187/veesem/archive/a569600f37e63b20c2e94dab69c6b8c55fbcbe80.tar.gz"
CHECKSUM_SHA256="7a99a918db18cda02877b9956d9de8bf4e209ecdb2fc3cfdaa40dea40e3f925a"
SOURCE_DIR="veesem-a569600f37e63b20c2e94dab69c6b8c55fbcbe80"
PATCHES="veesem-$portVersion.recipe"
REVISION="1"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

PROVIDES="
	veesem$secondaryArchSuffix = $portVersion
	cmd:veesem$secondaryArchSuffix
	"
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libgl$secondaryArchSuffix
	lib:libSDL2_2.0$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:libgl$secondaryArchSuffix
	devel:libsdl2$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	cmd:cmake
	cmd:gcc$secondaryArchSuffix
	cmd:ninja
	cmd:pkg_config$secondaryArchSuffix
	"

BUILD()
{
	mkdir -p build
	cd build
	cmake .. -GNinja -DCMAKE_BUILD_TYPE=Release -DNFD_PORTAL=OFF $cmakeDirArgs
	ninja $jobArgs
}

INSTALL()
{
	cd build
	ninja install
}
