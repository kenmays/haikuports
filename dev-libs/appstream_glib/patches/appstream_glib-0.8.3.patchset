From a271b99fc8fb867cd126d35bee2b941a4af56b75 Mon Sep 17 00:00:00 2001
From: Luc Schrijvers <begasus@gmail.com>
Date: Fri, 10 Jul 2026 12:19:36 +0200
Subject: Don't use hardcoded "share" path


diff --git a/data/installed-tests/meson.build b/data/installed-tests/meson.build
index bc96363..89ff927 100644
--- a/data/installed-tests/meson.build
+++ b/data/installed-tests/meson.build
@@ -10,13 +10,13 @@ configure_file(
   output : 'appdata-validate.test',
   configuration : con2,
   install: true,
-  install_dir: join_paths('share', 'installed-tests', 'appstream-glib'),
+  install_dir: join_paths('data', 'installed-tests', 'appstream-glib'),
 )
 configure_file(
   input : 'destdir-check.test.in',
   output : 'destdir-check.test',
   configuration : con2,
   install: true,
-  install_dir: join_paths('share', 'installed-tests', 'appstream-glib'),
+  install_dir: join_paths('data', 'installed-tests', 'appstream-glib'),
 )
 
diff --git a/data/meson.build b/data/meson.build
index 42e0346..09dc021 100644
--- a/data/meson.build
+++ b/data/meson.build
@@ -1,16 +1,16 @@
 subdir('installed-tests')
 subdir('tests')
 
-install_data('appdata-xml.m4', install_dir : 'share/aclocal')
-install_data('appstream-xml.m4', install_dir : 'share/aclocal')
-install_data('appstream-util', install_dir : 'share/bash-completion/completions')
+install_data('appdata-xml.m4', install_dir : 'data/aclocal')
+install_data('appstream-xml.m4', install_dir : 'data/aclocal')
+install_data('appstream-util', install_dir : 'data/bash-completion/completions')
 
 if get_option('builder')
-install_data('appstream-builder', install_dir : 'share/bash-completion/completions')
+install_data('appstream-builder', install_dir : 'data/bash-completion/completions')
 endif
 
-install_data('appdata.its', install_dir : 'share/gettext/its')
-install_data('appdata.loc', install_dir : 'share/gettext/its')
+install_data('appdata.its', install_dir : 'data/gettext/its')
+install_data('appdata.loc', install_dir : 'data/gettext/its')
 
 xsltproc = find_program('xsltproc', required : false)
 if get_option('man') and xsltproc.found()
-- 
2.54.0

