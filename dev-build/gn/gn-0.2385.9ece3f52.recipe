SUMMARY="A meta-build system that generates build files for Ninja"
DESCRIPTION="GN is a meta-build system that generates build files for Ninja"
HOMEPAGE="https://gn.googlesource.com/"
COPYRIGHT="2008-2019 The Chromium Authors."
LICENSE="BSD (3-clause)"
REVISION="1"
srcGitRev="9ece3f5254c273cb46606a6571963f931c3b012d"
SOURCE_URI="https://github.com/korli/gn/archive/$srcGitRev.tar.gz"
CHECKSUM_SHA256="b7a1d2de92a74a3e2a8122aa06789e7f9b8bbbaecdd8dfdb94a4b40a98e09d8f"
SOURCE_FILENAME="gn-$portVersion-$srcGitRev.tar.gz"
SOURCE_DIR="gn-$srcGitRev"
PATCHES="gn-$portVersion.patchset"

ARCHITECTURES="all !x86_gcc2"
if [ "$targetArchitecture" = x86_gcc2 ]; then
SECONDARY_ARCHITECTURES="x86"
fi

commandBinDir=$binDir
if [ "$targetArchitecture" = x86_gcc2 ]; then
	commandBinDir=$prefix/bin
fi

PROVIDES="
	gn$secondaryArchSuffix = $portVersion
	cmd:gn = $portVersion
	"
REQUIRES="
	haiku$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	"
BUILD_PREREQUIRES="
	cmd:gcc$secondaryArchSuffix
	cmd:g++$secondaryArchSuffix
	cmd:ninja
	cmd:python3
	cmd:git
	cmd:sed
	"

BUILD()
{
	export CC=gcc
	export CXX=g++

	GN_COMMIT_VERSION_SHORT=`echo $srcGitRev | cut -c 1-7`

	sed  -i \
		"s/(999999, 999999, \"091169b\")/(\"2385\", \"2385\", \"$GN_COMMIT_VERSION_SHORT\")/g" \
		build/gen.py

	python3 build/gen.py --host haiku --platform=haiku --allow-warnings
	ninja -C out $jobArgs
}

INSTALL()
{
	mkdir -p $commandBinDir
	cp out/gn $commandBinDir
}

TEST()
{
	./out/gn_unittests
}
